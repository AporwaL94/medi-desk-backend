{
  "openapi": "3.0.0",
  "info": {
    "title": "Kirana Desk API Documentation",
    "version": "1.0.0",
    "description": "API documentation for the Kirana Desk backend including Activation, Synchronization, and Admin Dashboard APIs."
  },
  "servers": [
    {
      "url": "https://bizdesk-backend.onrender.com",
      "description": "Production server"
    },
    {
      "url": "http://localhost:3000",
      "description": "Local server"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "Enter the JWT token obtained from activation."
      },
      "adminSecretAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-Admin-Secret",
        "description": "Enter the admin secret password."
      }
    },
    "schemas": {
      "Vendor": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "deviceId": { "type": "string" },
          "deviceName": { "type": "string", "nullable": true },
          "activatedAt": { "type": "string", "format": "date-time", "nullable": true },
          "plan": { "type": "string" },
          "planStarted": { "type": "string", "format": "date-time", "nullable": true },
          "planExpiry": { "type": "string", "format": "date-time", "nullable": true },
          "status": { "type": "string" },
          "gracePeriodEnd": { "type": "string", "format": "date-time", "nullable": true },
          "notes": { "type": "string", "nullable": true },
          "lastSyncAt": { "type": "string", "format": "date-time", "nullable": true },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "ActivationKey": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "key": { "type": "string" },
          "status": { "type": "string" },
          "plan": { "type": "string" },
          "label": { "type": "string", "nullable": true },
          "vendorId": { "type": "string", "format": "uuid", "nullable": true },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "Payment": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "vendorId": { "type": "string", "format": "uuid" },
          "amount": { "type": "number" },
          "plan": { "type": "string" },
          "method": { "type": "string" },
          "reference": { "type": "string", "nullable": true },
          "paidAt": { "type": "string", "format": "date-time" },
          "recordedBy": { "type": "string" },
          "notes": { "type": "string", "nullable": true },
          "durationDays": { "type": "integer" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "VendorProduct": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "vendorId": { "type": "string", "format": "uuid" },
          "localId": { "type": "string" },
          "name": { "type": "string" },
          "barcode": { "type": "string", "nullable": true },
          "price": { "type": "number" },
          "costPrice": { "type": "number", "nullable": true },
          "stock": { "type": "integer" },
          "category": { "type": "string", "nullable": true },
          "expiryDate": { "type": "string", "format": "date-time", "nullable": true },
          "imageUrl": { "type": "string", "nullable": true },
          "brand": { "type": "string", "nullable": true },
          "remoteUpdatedAt": { "type": "string", "format": "date-time", "nullable": true },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "VendorInvoice": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "vendorId": { "type": "string", "format": "uuid" },
          "localId": { "type": "string" },
          "invoiceNumber": { "type": "string" },
          "totalAmount": { "type": "number" },
          "customerName": { "type": "string", "nullable": true },
          "customerPhone": { "type": "string", "nullable": true },
          "items": { "type": "array", "items": { "type": "object" } },
          "invoiceCreatedAt": { "type": "string", "format": "date-time" },
          "remoteUpdatedAt": { "type": "string", "format": "date-time", "nullable": true },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "VendorShop": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "vendorId": { "type": "string", "format": "uuid" },
          "shopName": { "type": "string", "nullable": true },
          "address": { "type": "string", "nullable": true },
          "phone": { "type": "string", "nullable": true },
          "whatsappNumber": { "type": "string", "nullable": true },
          "upiId": { "type": "string", "nullable": true },
          "gstin": { "type": "string", "nullable": true },
          "logoUrl": { "type": "string", "nullable": true },
          "footerMessage": { "type": "string", "nullable": true },
          "remoteUpdatedAt": { "type": "string", "format": "date-time", "nullable": true },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      }
    }
  },
  "paths": {
    "/health": {
      "get": {
        "summary": "API health status",
        "description": "Check if the server is healthy and running.",
        "responses": {
          "200": {
            "description": "Healthy response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": { "type": "boolean" },
                    "service": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/activate": {
      "post": {
        "summary": "Activate a device",
        "description": "Activate Kirana Desk application for a device using an activation key.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["key", "deviceId"],
                "properties": {
                  "key": { "type": "string", "description": "Activation key" },
                  "deviceId": { "type": "string", "description": "Unique device identifier" },
                  "deviceName": { "type": "string", "description": "Friendly name of the device" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successfully activated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "token": { "type": "string", "description": "JWT authentication token" },
                    "vendorId": { "type": "string", "format": "uuid" },
                    "plan": { "type": "string" },
                    "planExpiry": { "type": "string", "format": "date-time", "nullable": true },
                    "status": { "type": "string" }
                  }
                }
              }
            }
          },
          "400": { "description": "Missing or invalid parameters" },
          "403": { "description": "Activation key has been revoked" },
          "404": { "description": "Invalid activation key" },
          "409": { "description": "Activation key already used on another device" }
        }
      }
    },
    "/api/validate": {
      "get": {
        "summary": "Validate vendor token",
        "description": "Check validity of current authorization token and retrieve license details.",
        "security": [
          { "bearerAuth": [] }
        ],
        "responses": {
          "200": {
            "description": "Token is valid",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "valid": { "type": "boolean" },
                    "vendorId": { "type": "string", "format": "uuid" },
                    "plan": { "type": "string" },
                    "planExpiry": { "type": "string", "format": "date-time", "nullable": true },
                    "gracePeriodEnd": { "type": "string", "format": "date-time", "nullable": true },
                    "status": { "type": "string" }
                  }
                }
              }
            }
          },
          "402": { "description": "Subscription expired" },
          "403": { "description": "Licence revoked" }
        }
      }
    },
    "/api/subscription/status": {
      "get": {
        "summary": "Get subscription status",
        "description": "Retrieve current subscription details and remaining days.",
        "security": [
          { "bearerAuth": [] }
        ],
        "responses": {
          "200": {
            "description": "Subscription status",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "vendorId": { "type": "string", "format": "uuid" },
                    "plan": { "type": "string" },
                    "planExpiry": { "type": "string", "format": "date-time", "nullable": true },
                    "gracePeriodEnd": { "type": "string", "format": "date-time", "nullable": true },
                    "status": { "type": "string" },
                    "daysRemaining": { "type": "integer", "nullable": true }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/sync/push": {
      "post": {
        "summary": "Push all records to sync",
        "description": "Synchronize products, invoices, and shop info all at once.",
        "security": [
          { "bearerAuth": [] }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "products": { "type": "array", "items": { "type": "object" } },
                  "invoices": { "type": "array", "items": { "type": "object" } },
                  "shop": { "type": "object" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Synchronization success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": { "type": "boolean" },
                    "syncedAt": { "type": "string", "format": "date-time" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/sync/pull": {
      "get": {
        "summary": "Pull all synced records",
        "description": "Retrieve all products, invoices, and shop info synced for this vendor.",
        "security": [
          { "bearerAuth": [] }
        ],
        "responses": {
          "200": {
            "description": "Retrieve success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "products": { "type": "array", "items": { "$ref": "#/components/schemas/VendorProduct" } },
                    "invoices": { "type": "array", "items": { "$ref": "#/components/schemas/VendorInvoice" } },
                    "shop": { "$ref": "#/components/schemas/VendorShop" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/sync/push/products": {
      "post": {
        "summary": "Sync products list",
        "description": "Send bulk vendor products to the cloud database.",
        "security": [
          { "bearerAuth": [] }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "products": { "type": "array", "items": { "type": "object" } }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": { "type": "boolean" },
                    "syncedAt": { "type": "string", "format": "date-time" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/sync/push/invoices": {
      "post": {
        "summary": "Sync invoices list",
        "description": "Send bulk vendor invoices/sales to the cloud database.",
        "security": [
          { "bearerAuth": [] }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "invoices": { "type": "array", "items": { "type": "object" } }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": { "type": "boolean" },
                    "syncedAt": { "type": "string", "format": "date-time" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/sync/push/shop": {
      "post": {
        "summary": "Sync shop profile",
        "description": "Send current shop configuration to the cloud database.",
        "security": [
          { "bearerAuth": [] }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "shop": { "type": "object" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": { "type": "boolean" },
                    "syncedAt": { "type": "string", "format": "date-time" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/sync/status": {
      "get": {
        "summary": "Sync summary info",
        "description": "Retrieve sync timestamp and database counts for vendor.",
        "security": [
          { "bearerAuth": [] }
        ],
        "responses": {
          "200": {
            "description": "Sync status data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "lastSync": { "type": "string", "format": "date-time", "nullable": true },
                    "productCount": { "type": "integer" },
                    "invoiceCount": { "type": "integer" },
                    "pendingRecords": { "type": "integer" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/admin/vendors": {
      "get": {
        "summary": "List all vendors",
        "tags": ["Admin"],
        "security": [
          { "adminSecretAuth": [] }
        ],
        "responses": {
          "200": {
            "description": "Array of vendors",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Vendor" }
                }
              }
            }
          }
        }
      }
    },
    "/admin/vendors/{id}": {
      "get": {
        "summary": "Get vendor details",
        "tags": ["Admin"],
        "security": [
          { "adminSecretAuth": [] }
        ],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": {
            "description": "Vendor details with shop profile nested",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/Vendor" },
                    {
                      "type": "object",
                      "properties": {
                        "shop": { "$ref": "#/components/schemas/VendorShop" }
                      }
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/admin/vendors/{id}/plan": {
      "put": {
        "summary": "Update vendor plan",
        "tags": ["Admin"],
        "security": [
          { "adminSecretAuth": [] }
        ],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["plan"],
                "properties": {
                  "plan": { "type": "string", "enum": ["none", "monthly", "yearly", "lifetime"] },
                  "durationDays": { "type": "integer", "description": "Optional custom duration" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Plan updated successfully" }
        }
      }
    },
    "/admin/vendors/{id}/revoke": {
      "post": {
        "summary": "Revoke vendor license",
        "tags": ["Admin"],
        "security": [
          { "adminSecretAuth": [] }
        ],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "License revoked successfully" }
        }
      }
    },
    "/admin/vendors/{id}/restore": {
      "post": {
        "summary": "Restore vendor license",
        "tags": ["Admin"],
        "security": [
          { "adminSecretAuth": [] }
        ],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "License restored successfully" }
        }
      }
    },
    "/admin/vendors/{id}/reset-device": {
      "post": {
        "summary": "Reset device assignment",
        "tags": ["Admin"],
        "security": [
          { "adminSecretAuth": [] }
        ],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "Device reset successful" }
        }
      }
    },
    "/admin/vendors/{id}/products": {
      "get": {
        "summary": "List vendor products",
        "tags": ["Admin"],
        "security": [
          { "adminSecretAuth": [] }
        ],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": {
            "description": "List of vendor products",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/VendorProduct" } }
              }
            }
          }
        }
      }
    },
    "/admin/vendors/{id}/invoices": {
      "get": {
        "summary": "List vendor invoices",
        "tags": ["Admin"],
        "security": [
          { "adminSecretAuth": [] }
        ],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": {
            "description": "List of vendor invoices",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/VendorInvoice" } }
              }
            }
          }
        }
      }
    },
    "/admin/keys/generate": {
      "post": {
        "summary": "Generate activation keys",
        "tags": ["Admin"],
        "security": [
          { "adminSecretAuth": [] }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["plan"],
                "properties": {
                  "count": { "type": "integer", "default": 5 },
                  "plan": { "type": "string", "enum": ["monthly", "yearly", "lifetime"] },
                  "label": { "type": "string", "nullable": true }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Keys generated successfully" }
        }
      }
    },
    "/admin/keys": {
      "get": {
        "summary": "List all activation keys",
        "tags": ["Admin"],
        "security": [
          { "adminSecretAuth": [] }
        ],
        "responses": {
          "200": {
            "description": "List of keys",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/ActivationKey" } }
              }
            }
          }
        }
      }
    },
    "/admin/keys/{id}": {
      "delete": {
        "summary": "Delete activation key",
        "tags": ["Admin"],
        "security": [
          { "adminSecretAuth": [] }
        ],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "Key deleted successfully" }
        }
      }
    },
    "/admin/keys/{id}/revoke": {
      "post": {
        "summary": "Revoke activation key",
        "tags": ["Admin"],
        "security": [
          { "adminSecretAuth": [] }
        ],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": { "description": "Key revoked successfully" }
        }
      }
    },
    "/admin/payments": {
      "post": {
        "summary": "Record a new payment",
        "tags": ["Admin"],
        "security": [
          { "adminSecretAuth": [] }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["vendorId", "amount", "plan", "method"],
                "properties": {
                  "vendorId": { "type": "string", "format": "uuid" },
                  "amount": { "type": "number" },
                  "plan": { "type": "string", "enum": ["monthly", "yearly", "lifetime"] },
                  "method": { "type": "string", "enum": ["cash", "upi", "other"] },
                  "reference": { "type": "string", "nullable": true },
                  "notes": { "type": "string", "nullable": true }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Payment recorded and subscription extended" }
        }
      },
      "get": {
        "summary": "List all recorded payments",
        "tags": ["Admin"],
        "security": [
          { "adminSecretAuth": [] }
        ],
        "responses": {
          "200": {
            "description": "List of payments",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Payment" } }
              }
            }
          }
        }
      }
    },
    "/admin/payments/vendor/{id}": {
      "get": {
        "summary": "List payments for a specific vendor",
        "tags": ["Admin"],
        "security": [
          { "adminSecretAuth": [] }
        ],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }
        ],
        "responses": {
          "200": {
            "description": "List of vendor payments",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Payment" } }
              }
            }
          }
        }
      }
    },
    "/admin/analytics/overview": {
      "get": {
        "summary": "Overview metrics",
        "tags": ["Admin"],
        "security": [
          { "adminSecretAuth": [] }
        ],
        "responses": {
          "200": {
            "description": "Revenue and vendor count overview",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "totalVendors": { "type": "integer" },
                    "activeVendors": { "type": "integer" },
